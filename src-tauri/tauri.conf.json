{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "deepnest",
  "version": "0.1.0",
  "identifier": "net.deepnest.rust",
  "build": {
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "RustyNesting",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
